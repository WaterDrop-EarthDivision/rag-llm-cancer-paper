#env variables the repository expects are listed here.
#to adapt to your own environment, make a copy of this file as .env and add in all keys mentioned.

MISTRAL_API_KEY=your-mistral-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# 该存储库所期望的环境变量已列出于此处。
# 若要适应您自己的环境，请将此文件复制为 .env 文件，并添加所有提及的键值。
MISTRAL_API_KEY = 您的 MISTRAL API 密钥（此处填入您的密钥）
OPENAI_API_KEY = 您的 OPENAI API 密钥（此处填入您的密钥）